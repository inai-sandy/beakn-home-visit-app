# Copy to .env.local and fill in real values. .env.local is gitignored.

# Postgres connection. In dev the beakn-postgres container is bound to 127.0.0.1:5432.
# In production this will be the container hostname on the mcp-network.
DATABASE_URL=postgresql://beakn_app:CHANGE_ME@127.0.0.1:5432/beakn_app
