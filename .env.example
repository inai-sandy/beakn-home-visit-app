# Copy to .env.local and fill in real values. .env.local is gitignored.
# This file is consumed by the beakn-app container at runtime (--env-file).
#
# Operational reference: docs/secrets.md
#
# Every value in this template is an obvious placeholder (CHANGE_ME or a
# canonical default). Real secret values MUST NOT be committed here — the
# real ones live in /opt/beakn-secrets/.env.production on the VPS and a
# backup copy in Sandeep's 1Password vault.

# -----------------------------------------------------------------------------
# Postgres (HVA-14)
# -----------------------------------------------------------------------------
# Both addresses below point at the same beakn-postgres daemon — pick based
# on where you're running from:
#   - From inside a container on mcp-network (e.g. beakn-app): beakn-postgres:5432
#   - From the host (e.g. drizzle-kit migrate, ad-hoc psql): 127.0.0.1:5432
# .env.local should use beakn-postgres:5432 so the container picks it up via
# --env-file. For host-side migrations run a one-off override:
#   DATABASE_URL=postgresql://beakn_app:PW@127.0.0.1:5432/beakn_app pnpm db:migrate
DATABASE_URL=postgresql://beakn_app:CHANGE_ME@beakn-postgres:5432/beakn_app

# -----------------------------------------------------------------------------
# Better-Auth (HVA-24)
# -----------------------------------------------------------------------------
# Generate a 32-byte random secret: `openssl rand -hex 32`. Keep stable across
# deploys; rotating this invalidates every active session — every signed-in
# user is forced back to /login. Document any rotation in the team channel
# before doing it.
BETTER_AUTH_SECRET=CHANGE_ME_32_BYTE_HEX

# Public origin Better-Auth uses for cookie scoping + redirect generation.
# Match the canonical domain Caddy serves the app from.
BETTER_AUTH_URL=https://visits.beakn.in

# -----------------------------------------------------------------------------
# App URL (read by lib/notifications/compose/*)
# -----------------------------------------------------------------------------
# Public origin used to build deep links inside notification emails (assign,
# reassign, etc.). Falls back to BETTER_AUTH_URL when unset. Set explicitly
# in prod so a future BA-URL change doesn't silently rewrite email links.
APP_URL=https://visits.beakn.in

# -----------------------------------------------------------------------------
# Logger (lib/logger.ts)
# -----------------------------------------------------------------------------
# pino level. Defaults to 'info' in production, 'debug' otherwise. Set to
# 'debug' temporarily when chasing a prod issue.
# LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Cloudflare Turnstile (HVA-34 — anti-spam on /request)
# -----------------------------------------------------------------------------
# Get keys from https://dash.cloudflare.com → Turnstile → site widget config.
#
# TURNSTILE_SITE_KEY and NEXT_PUBLIC_TURNSTILE_SITE_KEY must be the same
# value — the public alias is what Next.js ships to the client bundle.
# TURNSTILE_SECRET_KEY is server-only; never reference from a 'use client'
# file. Verify via bundle grep before each deploy (scripts/deploy.sh already
# does this check).
TURNSTILE_SITE_KEY=CHANGE_ME
NEXT_PUBLIC_TURNSTILE_SITE_KEY=CHANGE_ME
TURNSTILE_SECRET_KEY=CHANGE_ME

# -----------------------------------------------------------------------------
# Hostinger SMTP (HVA-40)
# -----------------------------------------------------------------------------
# Port 465 with implicit TLS (secure: true). The Linear body says 587 +
# STARTTLS but the verified working config is 465. Don't switch back without
# confirming with the operator — Hostinger's 587 endpoint behaves differently
# on shared hosting.
#
# SPF for beakn.in must include _spf.mail.hostinger.com; DKIM selectors
# hostingermail-a / hostingermail-b are managed in the Hostinger email panel.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=visits@beakn.in
SMTP_PASS=CHANGE_ME
SMTP_FROM=visits@beakn.in
SMTP_FROM_NAME=Beakn
SMTP_REPLY_TO=visits@beakn.in

# -----------------------------------------------------------------------------
# Web Push / VAPID (HVA-54 — not yet wired)
# -----------------------------------------------------------------------------
# Generate once with `npx web-push generate-vapid-keys`. The PUBLIC key gets
# shipped to the browser; the PRIVATE key signs the push payload server-side.
# Rotate ONLY if leaked — every existing browser subscription is bound to the
# public key and would need to re-subscribe after a rotation.
VAPID_PUBLIC_KEY=CHANGE_ME_VAPID_PUBLIC
VAPID_PRIVATE_KEY=CHANGE_ME_VAPID_PRIVATE

# -----------------------------------------------------------------------------
# Interakt WhatsApp API (Phase 2 — not yet wired)
# -----------------------------------------------------------------------------
# Two separate keys so we can swap between sandbox and prod numbers without a
# deploy. PROD points at the live business number; SANDBOX is the test number
# Interakt provisions per account. Get both from the Interakt dashboard →
# Developer Settings → API Keys.
INTERAKT_API_KEY_PROD=CHANGE_ME_INTERAKT_PROD
INTERAKT_API_KEY_SANDBOX=CHANGE_ME_INTERAKT_SANDBOX

# -----------------------------------------------------------------------------
# Discord routing (HVA-122 removed the consumer — placeholder retained)
# -----------------------------------------------------------------------------
# Discord-for-Other-city routing was defined in spec §1.4 but the consumer was
# never shipped (current "Other" flow routes via email to super_admins —
# lib/notifications/email-handlers/captain-new-request.ts). Placeholder kept
# here so reintroducing Discord-for-Other doesn't require an .env.example
# round-trip; leave UNSET in production until that feature is built.
# DISCORD_WEBHOOK_OTHER_ORDERS=CHANGE_ME

# -----------------------------------------------------------------------------
# /dev/email-test escape hatch (HVA-40 + HVA-99)
# -----------------------------------------------------------------------------
# Allows super_admin to reach /dev/email-test on production for deliverability
# verification. Leave UNSET unless you're actively running a smoke test.
# /dev/* is otherwise blocked on production per HVA-99.
# DEV_ROUTES_ENABLED=true

# -----------------------------------------------------------------------------
# Cron secret (HVA-169)
# -----------------------------------------------------------------------------
# Bearer token gating /api/cron/* endpoints. Host crontab on the VPS reads
# the live value out of .env.local and passes it on each call. The endpoint
# refuses ALL requests when this is unset — never become an open scheduler
# by accident. Generate with: openssl rand -hex 32
# See docs/cron.md for install steps.
CRON_SECRET=CHANGE_ME_CRON_SECRET
