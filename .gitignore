# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code (local agent settings, not project state)
.claude/

# playwright (HVA-151) — generated artifacts. Visual baselines under
# tests/e2e/**/*-snapshots/ are committed deliberately.
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# HVA-198 e2e — testcontainer credentials regenerated per run
tests/e2e/.e2e-users.json

# HVA-138 vitest browser-mode — failure screenshots + per-test attachments.
# Recreated on every failing run; never useful in git.
.vitest-attachments/
tests/components/__screenshots__/
