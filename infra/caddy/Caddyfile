dataforseo.1site.ai {
	reverse_proxy dataforseo-mcp:3000
}
mem0.1site.ai {
	reverse_proxy mcp-mem0:8050
}
rag.1site.ai {
	reverse_proxy rag-mcp:8050
}

# Beakn Home Visit App (HVA-15). Cloudflare proxy is OFF for this subdomain so
# DNS resolves direct to the VPS, matching the *.1site.ai pattern above.
# Next.js currently runs on the host at :3001 (changed from :3000 because
# dataforseo-mcp owns host port 3000). Caddy reaches the host via the
# mcp-network gateway IP. When Next.js is containerised + joined to
# mcp-network, swap the upstream to `beakn-app:3001`.
visits.beakn.in {
	reverse_proxy 172.18.0.1:3001
}
